# PolisRoad Environment Variables (.env.example)
# Copia questo file in .env e compila con i tuoi valori

# ==========================================
# SUPABASE (Backend - Opzionale)
# ==========================================
# Se non configuri Supabase, l'app funzionerà in modalità offline con mock data

VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==========================================
# DEMO MODE (Sviluppo & Testing)
# ==========================================
# Abilita la modalità demo per testare senza Supabase

VITE_DEMO_MODE=false
VITE_DEMO_USER_ID=demo-1
VITE_DEMO_USER_EMAIL=admin@polisroad.it
VITE_DEMO_USER_PASSWORD=change-me
VITE_DEMO_USER_ROLE=operatore

# ==========================================
# ANALYTICS (PostHog - Opzionale)
# ==========================================
# Tracciamento eventi e analytics

VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxx
VITE_POSTHOG_HOST=https://app.posthog.com

# ==========================================
# APP CONFIGURATION
# ==========================================

# Usare Supabase come backend (true/false)
VITE_USE_SUPABASE=true

# La versione dell'app NON si imposta qui: viene scritta automaticamente in
# src/config/constants.js da `npm run build` / `npm run dev` a partire dalla
# "version" di package.json (vedi scripts/update-version.js). Non esiste una
# VITE_APP_VERSION effettivamente letta dal codice — se la vedi citata in
# documentazione più vecchia, è superata.

# Opzionale: forza un valore specifico per invalidare la cache locale
# (IndexedDB) della query cache ad ogni deploy. Se non impostata, usa
# automaticamente la versione dell'app (comportamento consigliato per
# la maggior parte dei casi: non serve impostarla).
VITE_CACHE_BUSTER=

# ==========================================
# NOTE IMPORTANTI
# ==========================================
# 
# 1. SICUREZZA
#    - Mai commitare questo file in versione con dati reali
#    - Usa .gitignore per escludere .env
#    - Cambia le password di demo in produzione
#
# 2 SUPABASE
#    - Usa l'ANON_KEY (non SECRET_KEY) nei client web
#    - Configura RLS policies sul database
#    - Mantieni i dati sensibili sul backend
#
# 3 DEMO MODE
#    - Utile per testare senza Supabase
#    - Disabilita in produzione (VITE_DEMO_MODE=false)
#    - I dati vengono salvati in localStorage
#
# 4 VERCEL DEPLOYMENT
#    - Aggiungi queste variabili in: Project Settings > Environment Variables
#    - Vercel li inietterà automaticamente durante il build

# ==========================================
# ERROR MONITORING (Sentry - Opzionale)
# ==========================================
# Cattura eccezioni JS in produzione.
# Ottieni il DSN su: https://sentry.io → Project Settings → Client Keys
# Lascia vuoto per disabilitare (in dev è sempre disabilitato)

VITE_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# Chiave pubblica VAPID per le notifiche push PWA.
# Genera le chiavi con: npx web-push generate-vapid-keys
# La chiave privata va impostata come secret nell'Edge Function send-push (non qui!)

VITE_VAPID_PUBLIC_KEY=BxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxA
